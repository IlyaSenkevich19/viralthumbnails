# --- Frontend (Next.js) — required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# --- Frontend — optional ---
# NEXT_PUBLIC_APP_NAME=Viral Thumbnails
#
# LEAD_INTAKE_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
# LEAD_INTAKE_DEBUG=1

# --- Backend (Nest) — required ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
FRONTEND_URL=http://localhost:3000
PORT=3001

# --- Backend — optional (defaults exist in code) ---
# SUPABASE_STORAGE_SIGN_EXPIRES_SEC=3600
#
# OpenRouter — key: https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://your-frontend.example
# OPENROUTER_APP_TITLE=ViralThumbnails
#
# Free-tier smoke test: default VIDEO + RANKING → openrouter/free (low daily limits).
# Image generation for project thumbnails still uses a paid image model (no :free image-output on OpenRouter).
# OPENROUTER_USE_FREE_MODELS=1
#
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview
# OPENROUTER_VIDEO_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_RANKING_MODEL=
# OPENROUTER_PROJECT_GEN_TIMEOUT_MS=120000
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# See apps/backend/README.md

# --- Frontend Route Handler only (YouTube inspiration, admin) ---
# YOUTUBE_DATA_API_KEY=
# ADMIN_USER_IDS=uuid1,uuid2

# Production: set the same keys on your host (Vercel etc.). After changing NEXT_PUBLIC_* → redeploy.
