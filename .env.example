# --- Frontend (Next.js) — required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# --- Frontend — optional ---
# NEXT_PUBLIC_APP_NAME=Viral Thumbnails

# --- Backend (Nest) — required ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
FRONTEND_URL=http://localhost:3000
PORT=3001

# --- Backend — optional (defaults exist in code) ---
# SUPABASE_STORAGE_SIGN_EXPIRES_SEC=3600
# OPENROUTER_API_KEY=   # without it: project gen uses placeholders; from-video needs a key for real work
# See apps/backend/README.md for OPENROUTER_* models, timeouts, BASE_URL, HTTP_REFERER, APP_TITLE.

# --- Frontend Route Handler only (YouTube inspiration, admin) ---
# YOUTUBE_DATA_API_KEY=
# ADMIN_USER_IDS=uuid1,uuid2

# Production: set the same keys on your host (Vercel etc.). After changing NEXT_PUBLIC_* → redeploy.
