# ===== Monorepo template — copy to .env =====

# Branding (synced to apps/frontend/.env.local)
NEXT_PUBLIC_APP_NAME=My App

# Where Next.js proxies /api/* in dev/build (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Supabase (frontend/public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Supabase (backend/server)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: absolute API base for client fetchJson() — leave empty to use same-origin /api (rewrites)
NEXT_PUBLIC_API_URL=

# NestJS listen port
PORT=3001

# CORS (NestJS)
FRONTEND_URL=http://localhost:3000